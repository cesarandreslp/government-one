// Schema del TENANT (fundación de dominio). Cada tenant tiene su propia BD Neon con
// ESTE schema. Aparte de la meta-DB (prisma/schema.prisma).
// Núcleo: estructura organizacional + cargos + vínculos persona↔cargo. Los módulos
// (contratación, presupuesto, …) se agregan encima en fases posteriores.
// Prisma 7: la URL de conexión NO va aquí; el cliente se crea con adapter por-tenant
// (ver src/lib/tenant-db.ts) y las migraciones se aplican por-tenant.

generator client {
  provider = "prisma-client"
  output   = "../../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
}

// ─── Identidad de plataforma (el rol NO modela funciones; eso son capacidades vía cargo) ───
enum RolUsuario {
  SUPER_ADMIN // admin máximo de la entidad
  ADMIN
  USER // funcionario genérico
  CONTRATISTA // identidad externa (portal), no ocupa cargo
}

enum DependenciaTipo {
  DESPACHO
  SECRETARIA
  SUBSECRETARIA
  DIRECCION
  OFICINA
}

enum VinculacionTipo {
  TITULAR
  ENCARGADO // cubre ausencias temporales
  PROVISIONAL // por resolución/decreto hasta concurso de méritos
}

enum AusenciaTipo {
  VACACIONES
  LICENCIA
  COMISION
  INCAPACIDAD
}

/// Árbol organizacional: Secretaría → Subsecretaría → Dirección → Oficina (profundidad libre).
model Dependencia {
  id          String          @id @default(cuid())
  codigo      String          @unique
  nombre      String
  tipo        DependenciaTipo @default(SECRETARIA)
  /// Servicio compartido/transversal (Jurídica, Contratación) que sirve a TODAS las dependencias.
  esServicioCompartido Boolean @default(false)
  activa      Boolean         @default(true)

  // Jerarquía
  padreId String?
  padre   Dependencia?  @relation("SubDependencias", fields: [padreId], references: [id])
  hijas   Dependencia[] @relation("SubDependencias")

  cargos    Cargo[]
  gdSeries  GdSerie[]
  radicados Radicado[]
  pqrsds    Pqrsd[]
  proyectos Proyecto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([padreId])
  @@map("dependencias")
}

/// Cargo (posición) dentro de una dependencia. Confiere un bundle de capacidades.
/// La asignación de trabajo va al CARGO; se resuelve a quien lo ejerce hoy.
model Cargo {
  id            String      @id @default(cuid())
  dependenciaId String
  dependencia   Dependencia @relation(fields: [dependenciaId], references: [id])
  nombre        String
  /// ¿Es el cargo cabeza de la dependencia? (fallback de ruteo/aprobación).
  esJefatura    Boolean     @default(false)
  /// Bundle de capacidades: { moduloId: capacidad[] }. Mismo formato que los grants por usuario.
  grants        Json        @default("{}")
  activo        Boolean     @default(true)

  vinculaciones VinculacionCargo[]
  pqrsds        Pqrsd[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dependenciaId])
  @@map("cargos")
}

/// Funcionario (persona) de la entidad. Identidad; las funciones vienen de sus cargos.
model Usuario {
  id       String     @id @default(cuid())
  email    String     @unique
  nombre   String
  apellido String
  rol      RolUsuario @default(USER)
  activo   Boolean    @default(true)
  /// Hash bcrypt de la contraseña del funcionario. Null = sin acceso (aún no se le fijó clave).
  /// Nunca se expone al cliente; la verificación compara en el servidor (ver tenant-auth.ts).
  passwordHash String?

  vinculaciones    VinculacionCargo[]
  ausencias        Ausencia[]
  radicados        Radicado[]
  pqrsdAsignadas   Pqrsd[]            @relation("PqrsdAsignada")
  pqrsdRespondidas Pqrsd[]            @relation("PqrsdRespondida")
  contratosEstructurados Contrato[]   @relation("ContratoEstructurador")
  contratosRevisados     Contrato[]   @relation("ContratoAbogado")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

/// Vínculo persona↔cargo. Una persona puede tener VARIOS vigentes (titular + encargos).
/// desde/hasta dan el snapshot histórico (auditoría: quién ejercía qué en el momento T).
model VinculacionCargo {
  id        String          @id @default(cuid())
  usuarioId String
  usuario   Usuario         @relation(fields: [usuarioId], references: [id])
  cargoId   String
  cargo     Cargo           @relation(fields: [cargoId], references: [id])
  tipo      VinculacionTipo @default(TITULAR)
  /// Acto administrativo (resolución/decreto) que soporta el nombramiento (encargo/provisional).
  actoAdmin String?
  desde     DateTime        @default(now())
  hasta     DateTime? // null = vigente

  createdAt DateTime @default(now())

  @@index([usuarioId])
  @@index([cargoId])
  @@map("vinculaciones_cargo")
}

/// Ausencia (vacaciones/licencia/…) — explica el hueco que llena un encargo (enriquecimiento RRHH).
model Ausencia {
  id        String       @id @default(cuid())
  usuarioId String
  usuario   Usuario      @relation(fields: [usuarioId], references: [id])
  tipo      AusenciaTipo
  desde     DateTime
  hasta     DateTime
  motivo    String?

  createdAt DateTime @default(now())

  @@index([usuarioId])
  @@map("ausencias")
}

// ─────────────────── Módulo base: GESTIÓN DOCUMENTAL (TRD + radicación) ───────────────────
// La Tabla de Retención Documental (TRD) es DATO del tenant (cada entidad aprueba la suya),
// no un catálogo nacional: Serie → Subserie por dependencia, con tiempos y disposición final.
// El radicado numera con consecutivo POR TENANT (por tipo y año), atómico.

enum GdTipoRadicado {
  ENTRADA // documento que llega del exterior
  SALIDA // documento que la entidad envía
  INTERNO // memorando/comunicación interna
}

enum GdEstadoRadicado {
  RADICADO
  EN_TRAMITE
  RESPONDIDO
  ARCHIVADO
  ANULADO
}

/// Disposición final de la subserie documental (norma AGN).
enum GdDisposicion {
  CONSERVACION_TOTAL
  ELIMINACION
  SELECCION
  DIGITALIZACION
}

/// Serie documental de la TRD, asociada a una dependencia productora.
model GdSerie {
  id            String      @id @default(cuid())
  dependenciaId String
  dependencia   Dependencia @relation(fields: [dependenciaId], references: [id])
  codigo        String
  nombre        String
  activa        Boolean     @default(true)

  subseries GdSubserie[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dependenciaId, codigo])
  @@index([dependenciaId])
  @@map("gd_series")
}

/// Subserie documental: nivel donde viven la retención y la disposición final.
model GdSubserie {
  id               String         @id @default(cuid())
  serieId          String
  serie            GdSerie        @relation(fields: [serieId], references: [id], onDelete: Cascade)
  codigo           String
  nombre           String
  retencionGestion Int? // años en archivo de gestión
  retencionCentral Int? // años en archivo central
  disposicion      GdDisposicion?
  activa           Boolean        @default(true)

  radicados Radicado[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serieId, codigo])
  @@index([serieId])
  @@map("gd_subseries")
}

/// Contador atómico del consecutivo de radicación, por tipo y año (numeración por tenant).
model GdConsecutivo {
  id     String         @id @default(cuid())
  tipo   GdTipoRadicado
  anio   Int
  ultimo Int            @default(0)

  @@unique([tipo, anio])
  @@map("gd_consecutivos")
}

/// Radicado: registro de entrada/salida/interno con número consecutivo único por tenant.
model Radicado {
  id          String           @id @default(cuid())
  numero      String           @unique // ej. E-2026-000001
  tipo        GdTipoRadicado
  anio        Int
  consecutivo Int
  asunto      String
  /// Remitente (ENTRADA) o destinatario (SALIDA); tercero externo, texto libre.
  tercero     String?
  estado      GdEstadoRadicado @default(RADICADO)

  // Ruteo a la dependencia responsable + clasificación TRD (opcional al radicar).
  dependenciaId String?
  dependencia   Dependencia? @relation(fields: [dependenciaId], references: [id])
  subserieId    String?
  subserie      GdSubserie?  @relation(fields: [subserieId], references: [id])

  radicadoPorId String?
  radicadoPor   Usuario? @relation(fields: [radicadoPorId], references: [id])

  fechaRadicado DateTime    @default(now())
  adjuntos      GdAdjunto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo, anio])
  @@index([dependenciaId])
  @@index([estado])
  @@map("radicados")
}

/// Adjunto de un radicado. El storage por-tenant llega después; por ahora referencia por URL.
model GdAdjunto {
  id         String   @id @default(cuid())
  radicadoId String
  radicado   Radicado @relation(fields: [radicadoId], references: [id], onDelete: Cascade)
  nombre     String
  url        String
  createdAt  DateTime @default(now())

  @@index([radicadoId])
  @@map("gd_adjuntos")
}

// ───────────────────── Módulo base: VENTANILLA ÚNICA (PQRSD) ─────────────────────
// La PQRSD entra y se asigna AUTOMÁTICAMENTE al funcionario que EJERCE el cargo competente
// (fundación de dominio: quienEjerce → encargado/titular sin ausencia → fallback). El acceso a
// las acciones es por CAPACIDAD ventanilla_unica (no por rol). Numeración por tenant/año.

enum PqrsdTipo {
  PETICION
  QUEJA
  RECLAMO
  SUGERENCIA
  DENUNCIA
}

enum PqrsdCanal {
  WEB
  PRESENCIAL
  TELEFONICO
  EMAIL
  ESCRITO
}

enum PqrsdEstado {
  RECIBIDA // sin asignar (nadie ejerce el cargo competente)
  ASIGNADA // asignada al funcionario que ejerce el cargo
  EN_TRAMITE
  RESPONDIDA
  CERRADA
}

/// Contador atómico del consecutivo de PQRSD, por año (numeración por tenant).
model PqrsdConsecutivo {
  id     String @id @default(cuid())
  anio   Int    @unique
  ultimo Int    @default(0)

  @@map("pqrsd_consecutivos")
}

/// Petición/Queja/Reclamo/Sugerencia/Denuncia ciudadana, con ruteo por cargo y término de ley.
model Pqrsd {
  id          String      @id @default(cuid())
  numero      String      @unique // ej. PQRSD-2026-000001
  anio        Int
  consecutivo Int
  tipo        PqrsdTipo
  canal       PqrsdCanal  @default(PRESENCIAL)
  estado      PqrsdEstado @default(RECIBIDA)

  // Peticionario (ciudadano)
  peticionarioNombre   String
  peticionarioEmail    String?
  peticionarioTelefono String?
  asunto               String
  descripcion          String

  // Ruteo por cargo (fundación de dominio): dependencia competente → cargo → quien lo ejerce hoy.
  dependenciaId     String?
  dependencia       Dependencia? @relation(fields: [dependenciaId], references: [id])
  cargoAsignadoId   String?
  cargoAsignado     Cargo?       @relation(fields: [cargoAsignadoId], references: [id])
  usuarioAsignadoId String?
  usuarioAsignado   Usuario?     @relation("PqrsdAsignada", fields: [usuarioAsignadoId], references: [id])

  // Términos de ley (días hábiles).
  fechaRecepcion   DateTime @default(now())
  diasTermino      Int
  fechaVencimiento DateTime

  // Respuesta
  respuesta       String?
  fechaRespuesta  DateTime?
  respondidoPorId String?
  respondidoPor   Usuario?  @relation("PqrsdRespondida", fields: [respondidoPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado])
  @@index([usuarioAsignadoId])
  @@index([dependenciaId])
  @@map("pqrsd")
}

// ───────────────────── Módulo: CONTABILIDAD (libro mayor, doble partida) ─────────────────────
// El plan de cuentas (CGC — Catálogo General de Cuentas, Res. CGN 533/2015 para entidades de
// gobierno) es CATÁLOGO NACIONAL (primitivo de plataforma, como CCPET/Res.1519): se siembra por
// tenant, editable. El motor es doble partida estricta: ∑débitos = ∑créditos por comprobante.

enum Naturaleza {
  DEBITO
  CREDITO
}

enum TipoCuenta {
  BALANCE // activo / pasivo / patrimonio
  RESULTADO // ingreso / gasto
  ORDEN // cuentas de orden / control
}

enum EstadoPeriodo {
  ABIERTO
  CERRADO
  AJUSTE // solo administración puede registrar
}

enum TipoComprobante {
  CONTABLE
  EGRESO
  INGRESO
  AJUSTE
  APERTURA
  CIERRE
}

enum EstadoComprobante {
  REGISTRADO
  ANULADO
}

enum TipoDocumento {
  NIT
  CC
  CE
  PA
  OTRO
}

/// Plan de cuentas (CGC), jerárquico. Solo las hojas (`permiteMovimientos`) reciben asientos.
model PlanCuenta {
  id                 String       @id @default(cuid())
  codigo             String       @unique // ej. "1110", "111005"
  nombre             String
  nivel              Int // 1=clase 2=grupo 3=cuenta 4=subcuenta
  naturaleza         Naturaleza
  tipo               TipoCuenta
  activa             Boolean      @default(true)
  permiteMovimientos Boolean      @default(false)

  parentId String?
  parent   PlanCuenta?  @relation("CuentaJerarquia", fields: [parentId], references: [id])
  hijos    PlanCuenta[] @relation("CuentaJerarquia")
  asientos Asiento[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([nivel])
  @@map("cp_plan_cuentas")
}

/// Periodo contable (mensual o anual). Los comprobantes se registran contra un periodo ABIERTO.
model PeriodoContable {
  id          String        @id @default(cuid())
  codigo      String        @unique // "2026-05" o "2026"
  anio        Int
  mes         Int? // 1..12, null = anual
  estado      EstadoPeriodo @default(ABIERTO)
  fechaInicio DateTime
  fechaFin    DateTime
  cerradoEn   DateTime?
  cerradoPor  String?

  comprobantes Comprobante[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([anio, mes])
  @@map("cp_periodos")
}

/// Tercero auxiliar (NIT/CC): proveedor, contratista, beneficiario. Registro compartido.
model Tercero {
  id            String        @id @default(cuid())
  documento     String        @unique
  tipoDocumento TipoDocumento @default(NIT)
  razonSocial   String
  email         String?
  telefono      String?
  activo        Boolean       @default(true)

  asientos  Asiento[]
  rps       Rp[]
  contratos Contrato[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([razonSocial])
  @@map("cp_terceros")
}

/// Contador atómico del consecutivo de comprobantes, por tipo y año.
model ComprobanteConsecutivo {
  id     String          @id @default(cuid())
  tipo   TipoComprobante
  anio   Int
  ultimo Int             @default(0)

  @@unique([tipo, anio])
  @@map("cp_consecutivos")
}

/// Comprobante contable (encabezado). Agrupa N asientos que cuadran (∑D = ∑C).
model Comprobante {
  id           String            @id @default(cuid())
  numero       String            @unique // "CC-2026-000123"
  tipo         TipoComprobante   @default(CONTABLE)
  fecha        DateTime
  descripcion  String
  estado       EstadoComprobante @default(REGISTRADO)
  periodoId    String
  periodo      PeriodoContable   @relation(fields: [periodoId], references: [id])
  anio         Int
  consecutivo  Int
  totalDebito  Decimal           @db.Decimal(18, 2)
  totalCredito Decimal           @db.Decimal(18, 2)

  asientos Asiento[]
  pago     Pago?

  // Trazabilidad cruzada (presupuesto/nómina/… postean aquí).
  fuenteModulo    String?
  fuenteRef       String?
  creadoPor       String?
  anuladoEn       DateTime?
  anuladoPor      String?
  motivoAnulacion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([periodoId])
  @@index([fecha])
  @@index([fuenteModulo, fuenteRef])
  @@map("cp_comprobantes")
}

/// Asiento (línea de débito o crédito de un comprobante).
model Asiento {
  id            String      @id @default(cuid())
  comprobanteId String
  comprobante   Comprobante @relation(fields: [comprobanteId], references: [id], onDelete: Cascade)
  cuentaId      String
  cuenta        PlanCuenta  @relation(fields: [cuentaId], references: [id])
  terceroId     String?
  tercero       Tercero?    @relation(fields: [terceroId], references: [id])
  debito        Decimal     @default(0) @db.Decimal(18, 2)
  credito       Decimal     @default(0) @db.Decimal(18, 2)
  descripcion   String?

  createdAt DateTime @default(now())

  @@index([comprobanteId])
  @@index([cuentaId])
  @@index([terceroId])
  @@map("cp_asientos")
}

// ───────────────────── Módulo: PRESUPUESTO (CDP → RP → Obligación → Pago) ─────────────────────
// El catálogo de clasificación (CCPET — Catálogo de Clasificación Presupuestal para Entidades
// Territoriales, MinHacienda) es CATÁLOGO NACIONAL (primitivo de plataforma, paralelo al CGC de
// Contabilidad — clasifica EN QUÉ se gasta/de dónde viene el ingreso, no el libro mayor). Este
// primer corte cubre Rubro + Apropiación (vigencia) + CDP (Certificado de Disponibilidad
// Presupuestal) con validación de saldo disponible; RP/Obligación/Pago quedan para el siguiente
// incremento del mismo módulo.

enum RubroTipo {
  INGRESO
  GASTO
}

enum EstadoDocPresupuestal {
  VIGENTE
  ANULADO
}

/// Rubro presupuestal (CCPET), jerárquico. Solo las hojas (`permiteMovimientos`) reciben CDP.
model RubroPresupuestal {
  id                 String    @id @default(cuid())
  codigo             String    @unique // ej. "2.3.1.01.01" (CCPET, hasta 10 niveles)
  nombre             String
  tipo               RubroTipo
  nivel              Int
  permiteMovimientos Boolean   @default(false)
  activo             Boolean   @default(true)

  parentId String?
  parent   RubroPresupuestal?  @relation("RubroJerarquia", fields: [parentId], references: [id])
  hijos    RubroPresupuestal[] @relation("RubroJerarquia")

  apropiaciones Apropiacion[]
  cdps          Cdp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
  @@index([tipo])
  @@map("psp_rubros")
}

/// Apropiación presupuestal de un rubro de GASTO para una vigencia (año fiscal). El disponible
/// se calcula al vuelo: (inicial + adiciones - reducciones) - Σ CDP vigentes del rubro/vigencia.
model Apropiacion {
  id                 String            @id @default(cuid())
  rubroId            String
  rubro              RubroPresupuestal @relation(fields: [rubroId], references: [id])
  vigencia           Int
  apropiacionInicial Decimal           @db.Decimal(18, 2)
  adiciones          Decimal           @default(0) @db.Decimal(18, 2)
  reducciones        Decimal           @default(0) @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([rubroId, vigencia])
  @@map("psp_apropiaciones")
}

/// Contador atómico del consecutivo de CDP, por vigencia.
model CdpConsecutivo {
  id       String @id @default(cuid())
  vigencia Int    @unique
  ultimo   Int    @default(0)

  @@map("psp_cdp_consecutivos")
}

/// CDP (Certificado de Disponibilidad Presupuestal) — reserva presupuestal previa a comprometer
/// el gasto. Valida `valor ≤ disponible` de la apropiación del rubro/vigencia al crearse.
model Cdp {
  id       String                @id @default(cuid())
  numero   String                @unique // "CDP-2026-000123"
  fecha    DateTime
  vigencia Int
  rubroId  String
  rubro    RubroPresupuestal     @relation(fields: [rubroId], references: [id])
  valor    Decimal               @db.Decimal(18, 2)
  objeto   String
  estado   EstadoDocPresupuestal @default(VIGENTE)

  proyectoId String?
  proyecto   Proyecto? @relation(fields: [proyectoId], references: [id])

  creadoPor       String?
  anuladoEn       DateTime?
  anuladoPor      String?
  motivoAnulacion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rps Rp[]

  @@index([proyectoId])

  @@index([rubroId, vigencia])
  @@index([vigencia])
  @@map("psp_cdps")
}

/// Contador atómico del consecutivo de RP, por vigencia.
model RpConsecutivo {
  id       String @id @default(cuid())
  vigencia Int    @unique
  ultimo   Int    @default(0)

  @@map("psp_rp_consecutivos")
}

/// RP (Registro Presupuestal de Compromiso) — afecta un CDP; formaliza el compromiso con un
/// tercero. Valida `valor ≤ disponible` del CDP (CDP.valor − Σ RP vigentes) al crearse.
model Rp {
  id        String                @id @default(cuid())
  numero    String                @unique // "RP-2026-000123"
  fecha     DateTime
  vigencia  Int
  cdpId     String
  cdp       Cdp                   @relation(fields: [cdpId], references: [id])
  terceroId String?
  tercero   Tercero?              @relation(fields: [terceroId], references: [id])
  valor     Decimal               @db.Decimal(18, 2)
  objeto    String
  estado    EstadoDocPresupuestal @default(VIGENTE)

  creadoPor       String?
  anuladoEn       DateTime?
  anuladoPor      String?
  motivoAnulacion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  obligaciones Obligacion[]
  contratos    Contrato[]

  @@index([cdpId])
  @@map("psp_rps")
}

/// Contador atómico del consecutivo de Obligación, por vigencia.
model ObligacionConsecutivo {
  id       String @id @default(cuid())
  vigencia Int    @unique
  ultimo   Int    @default(0)

  @@map("psp_obligacion_consecutivos")
}

/// Obligación (cuenta por pagar) — afecta un RP; el bien/servicio ya se recibió a satisfacción.
/// Valida `valor ≤ disponible` del RP (RP.valor − Σ Obligación vigentes) al crearse.
model Obligacion {
  id       String                @id @default(cuid())
  numero   String                @unique // "OB-2026-000123"
  fecha    DateTime
  rpId     String
  rp       Rp                    @relation(fields: [rpId], references: [id])
  valor    Decimal               @db.Decimal(18, 2)
  concepto String
  estado   EstadoDocPresupuestal @default(VIGENTE)

  creadoPor       String?
  anuladoEn       DateTime?
  anuladoPor      String?
  motivoAnulacion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pagos Pago[]

  @@index([rpId])
  @@map("psp_obligaciones")
}

enum MedioPago {
  TRANSFERENCIA
  CHEQUE
  EFECTIVO
  OTRO
}

/// Contador atómico del consecutivo de Pago, por vigencia.
model PagoConsecutivo {
  id       String @id @default(cuid())
  vigencia Int    @unique
  ultimo   Int    @default(0)

  @@map("psp_pago_consecutivos")
}

/// Pago — afecta una Obligación; cierra la cadena presupuestal Y contable en una sola
/// transacción: genera un Comprobante EGRESO (D gasto / C banco) en Contabilidad. Valida
/// `valor ≤ disponible` de la Obligación (Obligacion.valor − Σ Pago vigentes) al crearse.
model Pago {
  id           String                @id @default(cuid())
  numero       String                @unique // "PG-2026-000123"
  fecha        DateTime
  obligacionId String
  obligacion   Obligacion            @relation(fields: [obligacionId], references: [id])
  valor        Decimal               @db.Decimal(18, 2)
  medioPago    MedioPago             @default(TRANSFERENCIA)
  referencia   String?
  comprobanteId String               @unique
  comprobante  Comprobante           @relation(fields: [comprobanteId], references: [id])
  estado       EstadoDocPresupuestal @default(VIGENTE)

  creadoPor       String?
  anuladoEn       DateTime?
  anuladoPor      String?
  motivoAnulacion String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([obligacionId])
  @@map("psp_pagos")
}

// ───────────────────── Módulo: BANCO DE PROYECTOS (financiera vs. física) ─────────────────────
// El diferenciador: ejecución FINANCIERA (derivada de CDP→RP→Obligación→Pago con proyectoId) vs.
// ejecución FÍSICA (independiente del dinero, por hitos ponderados reportados por el supervisor).
// La BRECHA entre ambas es la señal de riesgo (ej. anticipo pagado 50%/obra en campo 0%).
// Sin Contratación todavía (viene después en el orden) — la física se reporta por hito directo
// del proyecto, no por actividad de contrato; se revisará cuando exista Contratación.

enum ProyectoEstado {
  FORMULACION
  EJECUCION
  SUSPENDIDO
  CERRADO
}

/// Contador atómico del consecutivo de proyectos, por vigencia.
model ProyectoConsecutivo {
  id       String @id @default(cuid())
  vigencia Int    @unique
  ultimo   Int    @default(0)

  @@map("bp_proyecto_consecutivos")
}

model Proyecto {
  id            String         @id @default(cuid())
  codigo        String         @unique // "PRY-2026-001"
  nombre        String
  descripcion   String?
  vigencia      Int
  dependenciaId String
  dependencia   Dependencia    @relation(fields: [dependenciaId], references: [id])
  estado        ProyectoEstado @default(FORMULACION)
  valorTotal    Decimal?       @db.Decimal(18, 2) // presupuesto total planeado (informativo)

  fechaInicio      DateTime?
  fechaFinPrevista DateTime?
  creadoPor        String?

  hitos ProyectoHito[]
  cdps  Cdp[] // la ejecución financiera (y, transitivamente, los contratos vía Cdp→Rp→Contrato) cuelga de aquí

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dependenciaId])
  @@index([vigencia])
  @@map("bp_proyectos")
}

/// Hito del proyecto — unidad de avance FÍSICO, ponderado (Σ pesoPorcentual tiende a 100).
model ProyectoHito {
  id               String   @id @default(cuid())
  proyectoId       String
  proyecto         Proyecto @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  nombre           String
  descripcion      String?
  pesoPorcentual   Decimal  @db.Decimal(5, 2)
  avancePorcentual Decimal  @default(0) @db.Decimal(5, 2)

  fechaProgramada DateTime?
  // Snapshot del ÚLTIMO reporte (lectura rápida). El histórico auditable vive en los reportes.
  fechaReporte    DateTime?
  reportadoPor    String?
  evidenciaUrl    String?
  observacion     String?

  reportes ProyectoHitoReporte[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proyectoId])
  @@map("bp_proyecto_hitos")
}

/// Histórico auditable de reportes de avance físico — quién reportó qué, cuándo, con qué
/// evidencia. Insert-only (no se edita ni se borra), trazabilidad ante entes de control.
model ProyectoHitoReporte {
  id           String       @id @default(cuid())
  hitoId       String
  hito         ProyectoHito @relation(fields: [hitoId], references: [id], onDelete: Cascade)
  avancePorcentual Decimal  @db.Decimal(5, 2)
  evidenciaUrl String?
  observacion  String?
  reportadoPor String?

  createdAt DateTime @default(now())

  @@index([hitoId])
  @@map("bp_proyecto_hito_reportes")
}

// ───────────────────── Módulo: CONTRATACIÓN (Ley 80/1150) ─────────────────────
// Máquina de estados con GATING REAL POR PERSONA, no solo por capacidad: la capacidad
// (contratacion: elaborar/revisar_juridica/concepto_juridico/supervisar/aprobar, ya en el
// catálogo desde la fundación) dice qué TIPO de acción puede hacer alguien; la asignación
// (estructuradorId/abogadoAsignadoId) dice si es la persona correcta PARA ESTE contrato — las
// dos condiciones se exigen juntas (ver src/lib/contratacion/flujo.ts). Portado de personeriabuga
// (hallazgo explícito: sin el segundo chequeo, cualquiera con la capacidad podía aprobar su
// propio contrato como si fuera otro actor de la cadena).

enum ModalidadContratacion {
  LICITACION_PUBLICA
  SELECCION_ABREVIADA
  CONCURSO_MERITOS
  CONTRATACION_DIRECTA
  MINIMA_CUANTIA
}

enum EstadoContrato {
  BORRADOR
  EN_REVISION_JURIDICA
  DEVUELTO_ESTRUCTURACION
  PERFECCIONADO
  RP_REGISTRADO
  SUSCRITO
  EN_EJECUCION
  SUSPENDIDO
  TERMINADO
  INCUMPLIDO
  LIQUIDADO
}

enum TipoVersionContrato {
  BORRADOR_ESTRUCTURACION
  REVISION_JURIDICA
}

/// Contador atómico del consecutivo de contratos, por vigencia.
model ContratoConsecutivo {
  id       String @id @default(cuid())
  vigencia Int    @unique
  ultimo   Int    @default(0)

  @@map("con_consecutivos")
}

model Contrato {
  id            String                @id @default(cuid())
  numero        String                @unique // "C-2026-001"
  vigencia      Int
  objeto        String
  modalidad     ModalidadContratacion
  valorContrato Decimal               @db.Decimal(18, 2)
  plazoDias     Int?
  estado        EstadoContrato        @default(BORRADOR)

  terceroId String // contratista
  tercero   Tercero @relation(fields: [terceroId], references: [id])

  estructuradorId   String?
  estructurador     Usuario? @relation("ContratoEstructurador", fields: [estructuradorId], references: [id])
  abogadoAsignadoId String?
  abogadoAsignado   Usuario? @relation("ContratoAbogado", fields: [abogadoAsignadoId], references: [id])

  // Sin proyectoId propio a propósito: el proyecto (si el contrato financia uno) se deriva
  // SIEMPRE de Contrato → Rp → Cdp → Proyecto — esa cadena es la que ya alimenta el seguimiento
  // financiero real (ejecucionProyecto). Un campo separado aquí podría desalinearse del RP real
  // y romper el seguimiento sin que nadie lo note.
  rpId String? // obligatorio en la práctica desde RP_REGISTRADO en adelante (ver flujo.ts)
  rp   Rp?     @relation(fields: [rpId], references: [id])

  fechaSuscripcion DateTime?
  creadoPor        String?

  versiones ContratoVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([terceroId])
  @@index([vigencia])
  @@index([estructuradorId])
  @@index([abogadoAsignadoId])
  @@map("con_contratos")
}

/// Versión insert-only del contenido/revisión — cada borrador de estructuración y cada
/// respuesta de jurídica queda versionada, nunca se sobreescribe.
model ContratoVersion {
  id            String              @id @default(cuid())
  contratoId    String
  contrato      Contrato            @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  numeroVersion Int
  tipo          TipoVersionContrato
  contenido     String?
  aprobado      Boolean?
  observaciones String?
  autorId       String?

  createdAt DateTime @default(now())

  @@index([contratoId])
  @@map("con_contrato_versiones")
}
