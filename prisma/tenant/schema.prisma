// Schema del TENANT (fundación de dominio). Cada tenant tiene su propia BD Neon con
// ESTE schema. Aparte de la meta-DB (prisma/schema.prisma).
// Núcleo: estructura organizacional + cargos + vínculos persona↔cargo. Los módulos
// (contratación, presupuesto, …) se agregan encima en fases posteriores.
// Prisma 7: la URL de conexión NO va aquí; el cliente se crea con adapter por-tenant
// (ver src/lib/tenant-db.ts) y las migraciones se aplican por-tenant.

generator client {
  provider = "prisma-client"
  output   = "../../src/generated/tenant"
}

datasource db {
  provider = "postgresql"
}

// ─── Identidad de plataforma (el rol NO modela funciones; eso son capacidades vía cargo) ───
enum RolUsuario {
  SUPER_ADMIN // admin máximo de la entidad
  ADMIN
  USER // funcionario genérico
  CONTRATISTA // identidad externa (portal), no ocupa cargo
}

enum DependenciaTipo {
  DESPACHO
  SECRETARIA
  SUBSECRETARIA
  DIRECCION
  OFICINA
}

enum VinculacionTipo {
  TITULAR
  ENCARGADO // cubre ausencias temporales
  PROVISIONAL // por resolución/decreto hasta concurso de méritos
}

enum AusenciaTipo {
  VACACIONES
  LICENCIA
  COMISION
  INCAPACIDAD
}

/// Árbol organizacional: Secretaría → Subsecretaría → Dirección → Oficina (profundidad libre).
model Dependencia {
  id          String          @id @default(cuid())
  codigo      String          @unique
  nombre      String
  tipo        DependenciaTipo @default(SECRETARIA)
  /// Servicio compartido/transversal (Jurídica, Contratación) que sirve a TODAS las dependencias.
  esServicioCompartido Boolean @default(false)
  activa      Boolean         @default(true)

  // Jerarquía
  padreId String?
  padre   Dependencia?  @relation("SubDependencias", fields: [padreId], references: [id])
  hijas   Dependencia[] @relation("SubDependencias")

  cargos    Cargo[]
  gdSeries  GdSerie[]
  radicados Radicado[]
  pqrsds    Pqrsd[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([padreId])
  @@map("dependencias")
}

/// Cargo (posición) dentro de una dependencia. Confiere un bundle de capacidades.
/// La asignación de trabajo va al CARGO; se resuelve a quien lo ejerce hoy.
model Cargo {
  id            String      @id @default(cuid())
  dependenciaId String
  dependencia   Dependencia @relation(fields: [dependenciaId], references: [id])
  nombre        String
  /// ¿Es el cargo cabeza de la dependencia? (fallback de ruteo/aprobación).
  esJefatura    Boolean     @default(false)
  /// Bundle de capacidades: { moduloId: capacidad[] }. Mismo formato que los grants por usuario.
  grants        Json        @default("{}")
  activo        Boolean     @default(true)

  vinculaciones VinculacionCargo[]
  pqrsds        Pqrsd[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dependenciaId])
  @@map("cargos")
}

/// Funcionario (persona) de la entidad. Identidad; las funciones vienen de sus cargos.
model Usuario {
  id       String     @id @default(cuid())
  email    String     @unique
  nombre   String
  apellido String
  rol      RolUsuario @default(USER)
  activo   Boolean    @default(true)
  /// Hash bcrypt de la contraseña del funcionario. Null = sin acceso (aún no se le fijó clave).
  /// Nunca se expone al cliente; la verificación compara en el servidor (ver tenant-auth.ts).
  passwordHash String?

  vinculaciones    VinculacionCargo[]
  ausencias        Ausencia[]
  radicados        Radicado[]
  pqrsdAsignadas   Pqrsd[]            @relation("PqrsdAsignada")
  pqrsdRespondidas Pqrsd[]            @relation("PqrsdRespondida")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("usuarios")
}

/// Vínculo persona↔cargo. Una persona puede tener VARIOS vigentes (titular + encargos).
/// desde/hasta dan el snapshot histórico (auditoría: quién ejercía qué en el momento T).
model VinculacionCargo {
  id        String          @id @default(cuid())
  usuarioId String
  usuario   Usuario         @relation(fields: [usuarioId], references: [id])
  cargoId   String
  cargo     Cargo           @relation(fields: [cargoId], references: [id])
  tipo      VinculacionTipo @default(TITULAR)
  /// Acto administrativo (resolución/decreto) que soporta el nombramiento (encargo/provisional).
  actoAdmin String?
  desde     DateTime        @default(now())
  hasta     DateTime? // null = vigente

  createdAt DateTime @default(now())

  @@index([usuarioId])
  @@index([cargoId])
  @@map("vinculaciones_cargo")
}

/// Ausencia (vacaciones/licencia/…) — explica el hueco que llena un encargo (enriquecimiento RRHH).
model Ausencia {
  id        String       @id @default(cuid())
  usuarioId String
  usuario   Usuario      @relation(fields: [usuarioId], references: [id])
  tipo      AusenciaTipo
  desde     DateTime
  hasta     DateTime
  motivo    String?

  createdAt DateTime @default(now())

  @@index([usuarioId])
  @@map("ausencias")
}

// ─────────────────── Módulo base: GESTIÓN DOCUMENTAL (TRD + radicación) ───────────────────
// La Tabla de Retención Documental (TRD) es DATO del tenant (cada entidad aprueba la suya),
// no un catálogo nacional: Serie → Subserie por dependencia, con tiempos y disposición final.
// El radicado numera con consecutivo POR TENANT (por tipo y año), atómico.

enum GdTipoRadicado {
  ENTRADA // documento que llega del exterior
  SALIDA // documento que la entidad envía
  INTERNO // memorando/comunicación interna
}

enum GdEstadoRadicado {
  RADICADO
  EN_TRAMITE
  RESPONDIDO
  ARCHIVADO
  ANULADO
}

/// Disposición final de la subserie documental (norma AGN).
enum GdDisposicion {
  CONSERVACION_TOTAL
  ELIMINACION
  SELECCION
  DIGITALIZACION
}

/// Serie documental de la TRD, asociada a una dependencia productora.
model GdSerie {
  id            String      @id @default(cuid())
  dependenciaId String
  dependencia   Dependencia @relation(fields: [dependenciaId], references: [id])
  codigo        String
  nombre        String
  activa        Boolean     @default(true)

  subseries GdSubserie[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([dependenciaId, codigo])
  @@index([dependenciaId])
  @@map("gd_series")
}

/// Subserie documental: nivel donde viven la retención y la disposición final.
model GdSubserie {
  id               String         @id @default(cuid())
  serieId          String
  serie            GdSerie        @relation(fields: [serieId], references: [id], onDelete: Cascade)
  codigo           String
  nombre           String
  retencionGestion Int? // años en archivo de gestión
  retencionCentral Int? // años en archivo central
  disposicion      GdDisposicion?
  activa           Boolean        @default(true)

  radicados Radicado[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serieId, codigo])
  @@index([serieId])
  @@map("gd_subseries")
}

/// Contador atómico del consecutivo de radicación, por tipo y año (numeración por tenant).
model GdConsecutivo {
  id     String         @id @default(cuid())
  tipo   GdTipoRadicado
  anio   Int
  ultimo Int            @default(0)

  @@unique([tipo, anio])
  @@map("gd_consecutivos")
}

/// Radicado: registro de entrada/salida/interno con número consecutivo único por tenant.
model Radicado {
  id          String           @id @default(cuid())
  numero      String           @unique // ej. E-2026-000001
  tipo        GdTipoRadicado
  anio        Int
  consecutivo Int
  asunto      String
  /// Remitente (ENTRADA) o destinatario (SALIDA); tercero externo, texto libre.
  tercero     String?
  estado      GdEstadoRadicado @default(RADICADO)

  // Ruteo a la dependencia responsable + clasificación TRD (opcional al radicar).
  dependenciaId String?
  dependencia   Dependencia? @relation(fields: [dependenciaId], references: [id])
  subserieId    String?
  subserie      GdSubserie?  @relation(fields: [subserieId], references: [id])

  radicadoPorId String?
  radicadoPor   Usuario? @relation(fields: [radicadoPorId], references: [id])

  fechaRadicado DateTime    @default(now())
  adjuntos      GdAdjunto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo, anio])
  @@index([dependenciaId])
  @@index([estado])
  @@map("radicados")
}

/// Adjunto de un radicado. El storage por-tenant llega después; por ahora referencia por URL.
model GdAdjunto {
  id         String   @id @default(cuid())
  radicadoId String
  radicado   Radicado @relation(fields: [radicadoId], references: [id], onDelete: Cascade)
  nombre     String
  url        String
  createdAt  DateTime @default(now())

  @@index([radicadoId])
  @@map("gd_adjuntos")
}

// ───────────────────── Módulo base: VENTANILLA ÚNICA (PQRSD) ─────────────────────
// La PQRSD entra y se asigna AUTOMÁTICAMENTE al funcionario que EJERCE el cargo competente
// (fundación de dominio: quienEjerce → encargado/titular sin ausencia → fallback). El acceso a
// las acciones es por CAPACIDAD ventanilla_unica (no por rol). Numeración por tenant/año.

enum PqrsdTipo {
  PETICION
  QUEJA
  RECLAMO
  SUGERENCIA
  DENUNCIA
}

enum PqrsdCanal {
  WEB
  PRESENCIAL
  TELEFONICO
  EMAIL
  ESCRITO
}

enum PqrsdEstado {
  RECIBIDA // sin asignar (nadie ejerce el cargo competente)
  ASIGNADA // asignada al funcionario que ejerce el cargo
  EN_TRAMITE
  RESPONDIDA
  CERRADA
}

/// Contador atómico del consecutivo de PQRSD, por año (numeración por tenant).
model PqrsdConsecutivo {
  id     String @id @default(cuid())
  anio   Int    @unique
  ultimo Int    @default(0)

  @@map("pqrsd_consecutivos")
}

/// Petición/Queja/Reclamo/Sugerencia/Denuncia ciudadana, con ruteo por cargo y término de ley.
model Pqrsd {
  id          String      @id @default(cuid())
  numero      String      @unique // ej. PQRSD-2026-000001
  anio        Int
  consecutivo Int
  tipo        PqrsdTipo
  canal       PqrsdCanal  @default(PRESENCIAL)
  estado      PqrsdEstado @default(RECIBIDA)

  // Peticionario (ciudadano)
  peticionarioNombre   String
  peticionarioEmail    String?
  peticionarioTelefono String?
  asunto               String
  descripcion          String

  // Ruteo por cargo (fundación de dominio): dependencia competente → cargo → quien lo ejerce hoy.
  dependenciaId     String?
  dependencia       Dependencia? @relation(fields: [dependenciaId], references: [id])
  cargoAsignadoId   String?
  cargoAsignado     Cargo?       @relation(fields: [cargoAsignadoId], references: [id])
  usuarioAsignadoId String?
  usuarioAsignado   Usuario?     @relation("PqrsdAsignada", fields: [usuarioAsignadoId], references: [id])

  // Términos de ley (días hábiles).
  fechaRecepcion   DateTime @default(now())
  diasTermino      Int
  fechaVencimiento DateTime

  // Respuesta
  respuesta       String?
  fechaRespuesta  DateTime?
  respondidoPorId String?
  respondidoPor   Usuario?  @relation("PqrsdRespondida", fields: [respondidoPorId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado])
  @@index([usuarioAsignadoId])
  @@index([dependenciaId])
  @@map("pqrsd")
}
