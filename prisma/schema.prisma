// Meta-DB (control plane) de Government One.
// Directorio de la flota multi-tenant: cada Tenant apunta a su propia BD Neon.
// Prisma 7: la URL de conexión vive en prisma.config.ts, no aquí.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Estado del aprovisionamiento de la BD de un tenant (control plane).
enum TenantEstadoProvision {
  CREANDO_NEON
  APLICANDO_SCHEMA
  SEMBRANDO
  ACTIVO
  FALLIDO
  SUSPENDIDO
}

/// Un tenant = una entidad pública con su propia BD Neon (aislamiento fuerte).
/// El ruteo por dominio y el orquestador de migraciones leen de aquí.
/// Data-driven: sin datos de entidad quemados; todo entra como registro.
model Tenant {
  id          String @id @default(cuid())
  slug        String @unique
  nombre      String
  tipoEntidad String // ALCALDIA | PERSONERIA | GOBERNACION | MINISTERIO … (catálogo, no quemado)

  // Ruteo por dominio
  dominioPrincipal     String  @unique // subdominio gestionado: <slug>.ossgovernmentone.lat
  dominioPersonalizado String? @unique // dominio propio .gov.co, opcional

  // BD del tenant (Neon) — connection strings CIFRADAS
  neonProjectId     String?
  databaseUrl       String? @db.Text // cifrada (pooled, runtime)
  databaseUrlDirect String? @db.Text // cifrada (directa, migraciones)

  // Secretos por tenant (AES-256-GCM): IA / storage / SMTP / WhatsApp / SECOP
  secretosEncriptados String? @db.Text

  // Módulos CONTRATADOS (habilitados por el superadmin según el contrato). Array de moduloId
  // (los módulos base están siempre disponibles y no se listan aquí). Ver src/lib/modulos.ts.
  modulosContratados Json @default("[]")

  // Control plane
  schemaVersion   Int                   @default(0) // migraciones aplicadas a su BD
  estadoProvision TenantEstadoProvision @default(CREANDO_NEON)
  activo          Boolean               @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenants")
}

/// Superadmin de PLATAFORMA (SaaS) — opera el control plane (ciclo de vida de tenants, CMS del
/// landing). No es un usuario de tenant. Vive en la meta-DB; el login se valida contra esta tabla.
/// La contraseña se guarda SOLO como hash (bcrypt); nunca en claro.
model AdminPlataforma {
  id           String    @id @default(cuid())
  email        String    @unique
  nombre       String
  passwordHash String
  activo       Boolean   @default(true)
  ultimoIngreso DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins_plataforma")
}

/// CMS de PLATAFORMA: páginas públicas del SaaS (landing y otras) administradas desde el Superadmin.
/// Data-driven: el contenido vive aquí, no quemado en el código. Una página = varios bloques ordenados.
model PaginaCms {
  id        String       @id @default(cuid())
  slug      String       @unique // "landing", "precios", "contacto", …
  titulo    String
  publicada Boolean      @default(true)
  bloques   BloqueCms[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("paginas_cms")
}

/// Bloque de contenido de una página. `tipo` decide cómo se renderiza (hero, lista_valores,
/// lista_modulos, richtext…); `contenido` es el payload JSON tipado por el tipo. `clave` es
/// estable para poder ubicar el bloque desde el código sin depender del orden.
model BloqueCms {
  id        String    @id @default(cuid())
  paginaId  String
  pagina    PaginaCms @relation(fields: [paginaId], references: [id], onDelete: Cascade)
  clave     String // estable dentro de la página: "hero", "valores", "modulos"
  tipo      String
  orden     Int       @default(0)
  visible   Boolean   @default(true)
  contenido Json      @default("{}")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([paginaId, clave])
  @@map("bloques_cms")
}
